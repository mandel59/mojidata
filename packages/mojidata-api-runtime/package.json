{
  "name": "@mandel59/mojidata-api-runtime",
  "version": "1.8.0",
  "description": "Runtime helper package for mojidata-api",
  "repository": {
    "type": "git",
    "url": "https://github.com/mandel59/mojidata.git",
    "directory": "packages/mojidata-api-runtime"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser-worker": {
      "types": "./dist/browser-worker.d.ts",
      "require": "./dist/browser-worker.js",
      "default": "./dist/browser-worker.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "require": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "prepare": "tsc",
    "publish": "yarn prepare && yarn npm publish --access public"
  },
  "author": "Ryusei Yamaguchi",
  "license": "MIT",
  "dependencies": {
    "@mandel59/idsdb": "^1.7.0",
    "@mandel59/mojidata": "^1.7.0",
    "@mandel59/mojidata-api-core": "^1.8.0",
    "@mandel59/mojidata-api-hono": "^1.8.0",
    "@mandel59/mojidata-api-sqljs": "^1.8.0"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.5.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^5.4.1",
    "@types/node": "^24.10.4",
    "typescript": "^5.9.3"
  }
}
