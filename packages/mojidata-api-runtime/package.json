{
  "name": "@mandel59/mojidata-api-runtime",
  "version": "2.0.0",
  "description": "Runtime helper package for mojidata-api",
  "repository": {
    "type": "git",
    "url": "https://github.com/mandel59/mojidata.git",
    "directory": "packages/mojidata-api-runtime"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser-client": {
      "types": "./dist/lib/browser-client.d.ts",
      "require": "./dist/lib/browser-client.js",
      "default": "./dist/lib/browser-client.js"
    },
    "./worker-protocol": {
      "types": "./dist/lib/worker-protocol.d.ts",
      "require": "./dist/lib/worker-protocol.js",
      "default": "./dist/lib/worker-protocol.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "require": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "prepare": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc"
  },
  "author": "Ryusei Yamaguchi",
  "license": "MIT",
  "dependencies": {
    "@mandel59/mojidata-api-core": "^1.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.4",
    "typescript": "^5.9.3"
  }
}
