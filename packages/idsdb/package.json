{
  "name": "@mandel59/idsdb",
  "version": "1.6.2",
  "description": "SQLite databases and utilities for mojidata IDS",
  "repository": {
    "type": "git",
    "url": "https://github.com/mandel59/mojidata.git",
    "directory": "packages/idsdb"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./idsfind.db": "./idsfind.db",
    "./idsdecompose.db": "./idsdecompose.db"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "@types/**/*.d.ts",
    "lib/*.js",
    "lib/*.d.ts",
    "idsfind.db",
    "idsdecompose.db",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "prepare": "tsc && ts-node --files prepare.ts",
    "publish": "yarn prepare && yarn npm publish --access public"
  },
  "author": "Ryusei Yamaguchi",
  "license": "MIT",
  "dependencies": {
    "@mandel59/mojidata": "^1.6.2"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.5.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.4",
    "better-sqlite3": "^12.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
