{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "mojidata-api-d1",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "MOJIDATA_API_DEPLOYMENT": "default"
  },
  "d1_databases": [
    {
      "binding": "MOJIDATA_DB",
      "database_name": "mojidata-api-d1-mojidata-20260503-bg-20260504-d1-indexes-r20260507-unihan-views",
      "database_id": "869556cd-9a42-4423-9b22-cff4c1eafca2"
    },
    {
      "binding": "IDSFIND_DB",
      "database_name": "mojidata-api-d1-idsfind-20260503-bg-20260504-d1-indexes",
      "database_id": "18e0c4f7-006c-474c-87e2-a00de91bec98"
    }
  ],
  "env": {
    "staging": {
      "name": "mojidata-api-d1-staging",
      "vars": {
        "MOJIDATA_API_DEPLOYMENT": "staging"
      },
      "d1_databases": [
        {
          "binding": "MOJIDATA_DB",
          "database_name": "mojidata-api-d1-staging-mojidata",
          "database_id": "00000000-0000-0000-0000-000000000101"
        },
        {
          "binding": "IDSFIND_DB",
          "database_name": "mojidata-api-d1-staging-idsfind",
          "database_id": "00000000-0000-0000-0000-000000000102"
        }
      ]
    },
    "production": {
      "name": "mojidata-api-d1-production",
      "vars": {
        "MOJIDATA_API_DEPLOYMENT": "production"
      },
      "d1_databases": [
        {
          "binding": "MOJIDATA_DB",
          "database_name": "mojidata-api-d1-production-mojidata",
          "database_id": "00000000-0000-0000-0000-000000000201"
        },
        {
          "binding": "IDSFIND_DB",
          "database_name": "mojidata-api-d1-production-idsfind",
          "database_id": "00000000-0000-0000-0000-000000000202"
        }
      ]
    }
  }
}
