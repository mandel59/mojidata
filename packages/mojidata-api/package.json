{
  "name": "@mandel59/mojidata-api",
  "version": "1.7.1",
  "description": "Compatibility facade package for mojidata-api split packages",
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./api/v1/*": {
      "types": "./api/v1/*.d.ts",
      "require": "./api/v1/*.js",
      "default": "./api/v1/*.js"
    },
    "./app": {
      "types": "./app.d.ts",
      "require": "./app.js",
      "default": "./app.js"
    },
    "./browser-client": {
      "types": "./browser-client.d.ts",
      "require": "./browser-client.js",
      "default": "./browser-client.js"
    },
    "./browser-worker": {
      "types": "./browser-worker.d.ts",
      "require": "./browser-worker.js",
      "default": "./browser-worker.js"
    },
    "./core": {
      "types": "./core.d.ts",
      "require": "./core.js",
      "default": "./core.js"
    },
    "./hono": {
      "types": "./hono.d.ts",
      "require": "./hono.js",
      "default": "./hono.js"
    },
    "./node": {
      "types": "./node.d.ts",
      "require": "./node.js",
      "default": "./node.js"
    },
    "./runtime": {
      "types": "./runtime.d.ts",
      "require": "./runtime.js",
      "default": "./runtime.js"
    },
    "./sqljs": {
      "types": "./sqljs.d.ts",
      "require": "./sqljs.js",
      "default": "./sqljs.js"
    },
    "./api/v1/_lib/*": {
      "types": "./api/v1/_lib/*.d.ts",
      "require": "./api/v1/_lib/*.js",
      "default": "./api/v1/_lib/*.js"
    }
  },
  "files": [
    "*.js",
    "*.d.ts",
    "api/v1/*.js",
    "api/v1/*.d.ts",
    "api/v1/_lib/*.js",
    "api/v1/_lib/*.d.ts",
    "openapi.yaml",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node --import tsx ./server.ts",
    "dev": "tsx watch ./server.ts",
    "bench": "node --import tsx ./benchmarks/run.ts",
    "prepare": "tsc",
    "publish": "yarn prepare && yarn npm publish --access public",
    "test": "node --import tsx --test ./tests/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mandel59/mojidata-api-core": "^1.7.0",
    "@mandel59/mojidata-api-hono": "^1.7.0",
    "@mandel59/mojidata-api-runtime": "^1.7.0",
    "@mandel59/mojidata-api-sqljs": "^1.7.0"
  },
  "peerDependencies": {
    "@hono/node-server": "^1.19.7",
    "better-sqlite3": "^12.5.0"
  },
  "peerDependenciesMeta": {
    "@hono/node-server": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.7",
    "@types/better-sqlite3": "^5.4.1",
    "@types/node": "^24.10.4",
    "@types/sql.js": "^1.4.9",
    "better-sqlite3": "^12.5.0",
    "prettier": "^2.8.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
