{
  "name": "@mandel59/mojidata-api-core",
  "version": "1.8.0",
  "description": "Core backend-neutral composition utilities for mojidata-api",
  "repository": {
    "type": "git",
    "url": "https://github.com/mandel59/mojidata.git",
    "directory": "packages/mojidata-api-core"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "require": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "prepare": "tsc",
    "publish": "yarn prepare && yarn npm publish --access public"
  },
  "author": "Ryusei Yamaguchi",
  "license": "MIT",
  "dependencies": {
    "@mandel59/idsdb-utils": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.4",
    "typescript": "^5.9.3"
  }
}
